{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2021",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "types": ["node", "jest"],
    "typeRoots": ["./node_modules/@types", "../node_modules/@types"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
